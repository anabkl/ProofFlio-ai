NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3210

# Optional: set to "true" only after enabling the matching provider in the
# Supabase Auth dashboard. See docs/V3_SOCIAL_AUTH_SETUP.md. Leave unset (or
# any other value) to hide the button — no dead sign-in buttons are shown.
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=
NEXT_PUBLIC_AUTH_GITHUB_ENABLED=
NEXT_PUBLIC_AUTH_LINKEDIN_ENABLED=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://127.0.0.1:3210/auth/github/callback
GITHUB_TOKEN_ENCRYPTION_KEY=

# Optional: enables the provider adapter label only. Leave unset to keep deterministic suggestions only.
PROOFFOLIO_AI_PROVIDER=off

# Optional: enables credential-dependent Playwright onboarding tests locally.
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
